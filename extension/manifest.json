{
    "name": "Fast Lit Grabber",
    "description": "A tool to quickly and easily insert articles into Fast Lit to read.",
    "version": "1.0",
    "manifest_version": 3,
    "action": {
        "default_popup": "extension.html",
        "default_icon": "fast_lit_icon_128.png"
    },
    "permissions": [
        "tabs",
        "activeTab",
        "scripting"
    ]
}
